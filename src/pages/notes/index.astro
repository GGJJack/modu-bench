---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('notes', ({ data }) => data.status === 'published');
const notes = entries.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const categoryLabel: Record<string, string> = {
  announcement: '공지',
  worklog: '작업일지',
  experiment: '실험',
  memo: '잡담노트',
};

const formatDate = (d: Date) =>
  `${d.getFullYear()}년 ${d.getMonth() + 1}월 ${d.getDate()}일`;
---

<BaseLayout title="Notes - ModuBench">
  <main class="pt-32 pb-24 px-6 max-w-4xl mx-auto">
    <header class="mb-20">
      <span class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant">공지 · 작업일지 · 실험 · 잡담노트</span>
      <h1 class="text-4xl md:text-[3.5rem] font-bold leading-[1.1] tracking-tight text-on-surface mt-2 font-headline">
        Notes
      </h1>
      <p class="mt-6 text-base leading-relaxed text-on-surface-variant max-w-2xl">
        작업 중 마주친 문제, 결정의 배경, 실패한 시도와 그로부터의 교훈을 정리합니다.
      </p>
    </header>

    {notes.length === 0 ? (
      <p class="text-on-surface-variant">아직 작성된 노트가 없습니다.</p>
    ) : (
      <div class="divide-y divide-outline-variant/20">
        {notes.map((entry) => {
          const { title, date, summary, category, tags, cover, readingTime } = entry.data;
          const href = `${import.meta.env.BASE_URL}notes/${entry.id}`;
          return (
            <article class="group py-10 first:pt-0">
              <a href={href} class="flex gap-6 md:gap-8 items-start">
                <div class="flex-1 min-w-0 space-y-4">
                  <div class="flex items-center gap-3 text-xs font-medium flex-wrap">
                    <span class="text-primary">{formatDate(date)}</span>
                    <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                    <span class="text-on-surface-variant">{categoryLabel[category] ?? category}</span>
                    {readingTime && (
                      <>
                        <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                        <span class="text-on-surface-variant">{readingTime}분 읽기</span>
                      </>
                    )}
                  </div>
                  <h2 class="text-xl md:text-2xl font-semibold leading-snug tracking-tight text-on-surface group-hover:text-primary transition-colors">
                    {title}
                  </h2>
                  <p class="text-sm md:text-base leading-relaxed text-on-surface-variant line-clamp-2">
                    {summary}
                  </p>
                  {tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 pt-1">
                      {tags.map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded-full bg-surface-container-high text-on-surface-variant">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                {cover && (
                  <div class="shrink-0 w-32 md:w-48 overflow-hidden rounded-md bg-surface-container">
                    <img
                      src={cover}
                      alt=""
                      loading="lazy"
                      class="w-full h-auto aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    />
                  </div>
                )}
              </a>
            </article>
          );
        })}
      </div>
    )}
  </main>
</BaseLayout>
