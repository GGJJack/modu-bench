---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="ModuBench - Open Source AI Benchmark Hub">
  <main class="pt-24 pb-20 px-6 max-w-7xl mx-auto">
    <!-- Hero Section -->
    <section class="mb-24 mt-12">
      <div class="flex flex-col gap-4">
        <span class="text-xs font-semibold tracking-widest uppercase text-on-surface-variant font-label">
          Open Source Initiative
        </span>
        <h1 class="text-4xl md:text-[3.5rem] font-bold tracking-tight leading-[1.2] text-on-surface font-headline max-w-3xl">
          믿을 수 있는 협업형<br />오픈 소스 벤치마크 허브
        </h1>
        <p class="text-lg text-on-surface-variant max-w-2xl leading-relaxed mt-4">
          ModuBench는 전 세계 커뮤니티가 함께 만들어가는 AI 모델 평가 플랫폼입니다.
          투명한 지표와 실시간 데이터를 통해 차세대 인공지능의 성능을 정의합니다.
        </p>
      </div>
    </section>

    <!-- Real-time Performance Metrics: Bento Grid -->
    <section class="mb-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-surface-container-lowest p-8 rounded-xl data-glass shadow-[0_12px_40px_rgba(42,52,57,0.06)] flex flex-col justify-between h-48">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider font-label">활성 모델</span>
              <Icon name="material-symbols:model-training" class="w-5 h-5 text-primary" />
            </div>
            <h3 class="text-4xl font-bold text-on-surface font-headline">1,284</h3>
          </div>
          <div class="flex items-center gap-2 text-xs text-on-surface-variant">
            <span class="text-primary font-bold">+12%</span> 이번 주 대비 상승
          </div>
        </div>

        <div class="bg-surface-container-lowest p-8 rounded-xl data-glass shadow-[0_12px_40px_rgba(42,52,57,0.06)] flex flex-col justify-between h-48">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider font-label">오늘의 업데이트</span>
              <Icon name="material-symbols:update" class="w-5 h-5 text-primary" />
            </div>
            <h3 class="text-4xl font-bold text-on-surface font-headline">56</h3>
          </div>
          <div class="flex items-center gap-2 text-xs text-on-surface-variant">
            <span class="text-primary font-bold">14개</span> 신규 데이터셋 포함
          </div>
        </div>

        <div class="bg-surface-container-lowest p-8 rounded-xl data-glass shadow-[0_12px_40px_rgba(42,52,57,0.06)] flex flex-col justify-between h-48">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider font-label">총 벤치마크 실행</span>
              <Icon name="material-symbols:rocket-launch" class="w-5 h-5 text-primary" />
            </div>
            <h3 class="text-4xl font-bold text-on-surface font-headline">842.1k</h3>
          </div>
          <div class="flex items-center gap-2 text-xs text-on-surface-variant">
            평균 응답 속도 <span class="text-on-surface font-bold">142ms</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Recent Update Log: Timeline -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <span class="text-xs font-semibold tracking-widest uppercase text-on-surface-variant font-label">System Workflow</span>
        <h2 class="text-2xl font-semibold tracking-tight text-on-surface mt-2 font-headline">실시간 업데이트 로그</h2>
        <p class="text-on-surface-variant mt-4 text-sm leading-relaxed">
          ModuBench의 GitOps 워크플로우는 자동화된 스크래핑부터 검토, 병합, 배포까지 투명하게 공개됩니다.
        </p>
      </div>
      <div class="lg:col-span-8 flex flex-col gap-0 relative">
        <div class="absolute left-6 top-0 bottom-0 w-px bg-outline-variant/30"></div>

        <!-- Deploy -->
        <div class="relative pl-16 py-6 group">
          <div class="absolute left-[21px] top-8 w-10 h-px bg-outline-variant/30"></div>
          <div class="absolute left-4 top-7 w-4 h-4 rounded-full bg-primary ring-4 ring-background z-10"></div>
          <div class="bg-surface-container-low p-6 rounded-xl transition-all duration-200 hover:bg-surface-container border border-transparent hover:border-outline-variant/20">
            <div class="flex items-center justify-between mb-2">
              <span class="px-2 py-0.5 bg-primary-container text-on-primary-container text-[10px] font-bold rounded uppercase tracking-wider">Deploy</span>
              <span class="text-xs text-on-surface-variant font-medium">방금 전</span>
            </div>
            <h4 class="font-semibold text-on-surface mb-1">v4.2.0 메인 서버 배포 완료</h4>
            <p class="text-sm text-on-surface-variant">Llama-3 최적화 가중치가 프로덕션 환경에 반영되었습니다.</p>
          </div>
        </div>

        <!-- Merge -->
        <div class="relative pl-16 py-6 group">
          <div class="absolute left-[21px] top-8 w-10 h-px bg-outline-variant/30"></div>
          <div class="absolute left-4 top-7 w-4 h-4 rounded-full bg-outline-variant ring-4 ring-background z-10"></div>
          <div class="p-6 rounded-xl transition-all duration-200 hover:bg-surface-container-low">
            <div class="flex items-center justify-between mb-2">
              <span class="px-2 py-0.5 bg-surface-container-highest text-on-surface-variant text-[10px] font-bold rounded uppercase tracking-wider">Merge</span>
              <span class="text-xs text-on-surface-variant font-medium">14분 전</span>
            </div>
            <h4 class="font-semibold text-on-surface mb-1">PR #2104 병합됨</h4>
            <p class="text-sm text-on-surface-variant">벤치마크 데이터 유효성 검사 로직이 업데이트되었습니다.</p>
          </div>
        </div>

        <!-- Review -->
        <div class="relative pl-16 py-6 group">
          <div class="absolute left-[21px] top-8 w-10 h-px bg-outline-variant/30"></div>
          <div class="absolute left-4 top-7 w-4 h-4 rounded-full bg-outline-variant ring-4 ring-background z-10"></div>
          <div class="p-6 rounded-xl transition-all duration-200 hover:bg-surface-container-low">
            <div class="flex items-center justify-between mb-2">
              <span class="px-2 py-0.5 bg-surface-container-highest text-on-surface-variant text-[10px] font-bold rounded uppercase tracking-wider">Review</span>
              <span class="text-xs text-on-surface-variant font-medium">1시간 전</span>
            </div>
            <h4 class="font-semibold text-on-surface mb-1">신규 모델 성능 검토 중</h4>
            <p class="text-sm text-on-surface-variant">Mistral-7B-v0.3 모델의 벤치마크 결과 대조 확인이 진행 중입니다.</p>
          </div>
        </div>

        <!-- Scrape -->
        <div class="relative pl-16 py-6 group">
          <div class="absolute left-[21px] top-8 w-10 h-px bg-outline-variant/30"></div>
          <div class="absolute left-4 top-7 w-4 h-4 rounded-full bg-outline-variant ring-4 ring-background z-10"></div>
          <div class="p-6 rounded-xl transition-all duration-200 hover:bg-surface-container-low">
            <div class="flex items-center justify-between mb-2">
              <span class="px-2 py-0.5 bg-surface-container-highest text-on-surface-variant text-[10px] font-bold rounded uppercase tracking-wider">Scrape</span>
              <span class="text-xs text-on-surface-variant font-medium">3시간 전</span>
            </div>
            <h4 class="font-semibold text-on-surface mb-1">데이터 수집 자동화 실행</h4>
            <p class="text-sm text-on-surface-variant">HuggingFace에서 신규 릴리즈된 12개 모델의 메타데이터를 가져왔습니다.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
