---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Resources - ModuBench">
  <main class="pt-32 pb-24 px-6 max-w-5xl mx-auto">
    <!-- Hero Header -->
    <div class="mb-12">
      <span class="text-[0.7rem] font-bold uppercase tracking-[0.2em] text-primary mb-3 block">PREMIUM ENGINEERING ASSETS</span>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-on-surface mb-6 leading-tight font-headline">
        Free Resources for Precision Engineering
      </h1>
      <p class="text-lg text-on-surface-variant max-w-2xl leading-relaxed">
        정밀 공학 및 AI 벤치마킹을 위한 오픈 소스 라이브러리, 데이터셋 및 개발 도구를 확인해 보세요.
        모든 리소스는 엔지니어링 커뮤니티를 위해 무료로 제공됩니다.
      </p>
    </div>

    <!-- Filter Section -->
    <div class="flex flex-wrap items-center gap-2 mb-12">
      <button class="px-5 py-2 rounded-full bg-primary text-on-primary text-sm font-semibold shadow-sm transition-all">전체</button>
      <button class="px-5 py-2 rounded-full bg-surface-container-lowest text-on-surface-variant border border-outline-variant/30 text-sm font-medium hover:border-primary hover:text-primary transition-all">데이터셋</button>
      <button class="px-5 py-2 rounded-full bg-surface-container-lowest text-on-surface-variant border border-outline-variant/30 text-sm font-medium hover:border-primary hover:text-primary transition-all">API</button>
      <button class="px-5 py-2 rounded-full bg-surface-container-lowest text-on-surface-variant border border-outline-variant/30 text-sm font-medium hover:border-primary hover:text-primary transition-all">UI/UX</button>
      <button class="px-5 py-2 rounded-full bg-surface-container-lowest text-on-surface-variant border border-outline-variant/30 text-sm font-medium hover:border-primary hover:text-primary transition-all">도구</button>
    </div>

    <!-- Resource Gallery -->
    <div class="grid grid-cols-1 gap-8">
      <!-- Card 1 -->
      <div class="group bg-surface-container-lowest hover:shadow-[0_20px_50px_rgba(0,0,0,0.06)] transition-all duration-500 rounded-2xl overflow-hidden flex flex-col md:flex-row border border-outline-variant/10">
        <div class="w-full md:w-72 h-56 md:h-auto shrink-0 relative flex items-center justify-center overflow-hidden bg-gradient-to-br from-surface-container-low to-surface-container">
          <div class="z-10 bg-surface-container-lowest/40 backdrop-blur-md p-6 rounded-3xl border border-surface-container-lowest/50 shadow-sm group-hover:scale-110 transition-transform duration-500">
            <Icon name="material-symbols:architecture" class="w-12 h-12 text-primary/60" />
          </div>
        </div>
        <div class="p-8 flex-1 flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <Icon name="material-symbols:architecture" class="w-5 h-5 text-primary" />
              <h3 class="text-xl font-bold text-on-surface tracking-tight">정밀 계측 데이터셋 V2</h3>
            </div>
            <p class="text-on-surface-variant text-base leading-relaxed mb-8">
              다양한 산업용 부품의 정밀 계측 수치와 CAD 데이터를 포함하는 포괄적인 데이터셋입니다.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-md tracking-wider uppercase">#Free</span>
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-md tracking-wider uppercase">#OpenSource</span>
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-md tracking-wider uppercase">#Dataset</span>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="group bg-surface-container-lowest hover:shadow-[0_20px_50px_rgba(0,0,0,0.06)] transition-all duration-500 rounded-2xl overflow-hidden flex flex-col md:flex-row border border-outline-variant/10">
        <div class="w-full md:w-72 h-56 md:h-auto shrink-0 relative flex items-center justify-center overflow-hidden bg-gradient-to-br from-surface-container-low to-surface-container">
          <div class="z-10 bg-surface-container-lowest/40 backdrop-blur-md p-6 rounded-3xl border border-surface-container-lowest/50 shadow-sm group-hover:scale-110 transition-transform duration-500">
            <Icon name="material-symbols:api" class="w-12 h-12 text-primary/60" />
          </div>
        </div>
        <div class="p-8 flex-1 flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <Icon name="material-symbols:settings-input-component" class="w-5 h-5 text-primary" />
              <h3 class="text-xl font-bold text-on-surface tracking-tight">공학 시뮬레이션 API 래퍼</h3>
            </div>
            <p class="text-on-surface-variant text-base leading-relaxed mb-8">
              주요 물리 엔진과 시뮬레이션 소프트웨어를 Python 환경에서 손쉽게 제어할 수 있는 고성능 래퍼 라이브러리입니다.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-md tracking-wider uppercase">#API</span>
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-md tracking-wider uppercase">#Python</span>
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant text-[0.7rem] font-bold rounded-md tracking-wider uppercase">#Free</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Load More -->
    <div class="mt-20 flex justify-center">
      <button class="px-10 py-4 bg-surface-container-lowest text-primary border border-primary/20 text-sm font-bold rounded-xl hover:bg-primary hover:text-on-primary hover:border-primary shadow-[0_4px_12px_rgba(0,83,219,0.08)] transition-all duration-300">
        리소스 더 보기
      </button>
    </div>
  </main>
</BaseLayout>
