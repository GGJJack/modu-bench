---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';

import llmModels from '../data/models/llm.json';
import imageGenModels from '../data/models/image-gen.json';
import ttsModels from '../data/models/tts.json';
import sttModels from '../data/models/stt.json';
import multimodalModels from '../data/models/multimodal.json';

import llmBenchmarks from '../data/benchmarks/llm.json';
import imageGenBenchmarks from '../data/benchmarks/image-gen.json';
import ttsBenchmarks from '../data/benchmarks/tts.json';
import sttBenchmarks from '../data/benchmarks/stt.json';
import multimodalBenchmarks from '../data/benchmarks/multimodal.json';

const countScores = (scores: Record<string, Record<string, unknown>>) =>
  Object.values(scores).reduce((acc, modelScores) => acc + Object.keys(modelScores).length, 0);

const domains = [
  {
    id: 'llm',
    label: 'LLM',
    description: '대규모 언어 모델',
    icon: 'material-symbols:chat-outline',
    modelCount: llmModels.models.length,
    benchmarkCount: llmBenchmarks.benchmarks.length,
    scoreCount: countScores(llmBenchmarks.scores),
  },
  {
    id: 'image-gen',
    label: '이미지 생성',
    description: 'Text-to-Image',
    icon: 'material-symbols:image-outline',
    modelCount: imageGenModels.models.length,
    benchmarkCount: imageGenBenchmarks.benchmarks.length,
    scoreCount: countScores(imageGenBenchmarks.scores),
  },
  {
    id: 'tts',
    label: 'TTS',
    description: '음성 합성',
    icon: 'material-symbols:record-voice-over-outline',
    modelCount: ttsModels.models.length,
    benchmarkCount: ttsBenchmarks.benchmarks.length,
    scoreCount: countScores(ttsBenchmarks.scores),
  },
  {
    id: 'stt',
    label: 'STT',
    description: '음성 인식',
    icon: 'material-symbols:mic-outline',
    modelCount: sttModels.models.length,
    benchmarkCount: sttBenchmarks.benchmarks.length,
    scoreCount: countScores(sttBenchmarks.scores),
  },
  {
    id: 'multimodal',
    label: '멀티모달',
    description: '복합 모달리티',
    icon: 'material-symbols:hub-outline',
    modelCount: multimodalModels.models.length,
    benchmarkCount: multimodalBenchmarks.benchmarks.length,
    scoreCount: countScores(multimodalBenchmarks.scores),
  },
];
---

<BaseLayout title="AI 모델 성능 리더보드 - ModuBench">
  <main class="pt-32 pb-24 max-w-7xl mx-auto px-6">
    <!-- Hero Section -->
    <section class="mb-16">
      <div class="max-w-3xl">
        <span class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant mb-4 block">V4 정밀 벤치마크</span>
        <h1 class="text-5xl font-bold tracking-tight text-on-surface mb-6 leading-tight font-headline">AI 모델 성능 리더보드</h1>
        <p class="text-lg text-on-surface-variant leading-relaxed">
          추론, 지시 이행, 코딩 능력을 포함한 최신 오픈소스 및 폐쇄형 인공지능 모델의 성능 지표를 투명하게 공개합니다.
        </p>
      </div>
    </section>

    <!-- 도메인별 수집 현황 -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-lg font-semibold tracking-tight text-on-surface font-headline">도메인별 수집 현황</h2>
        <span class="text-xs text-on-surface-variant font-label">도메인별로 평가 방식·단위가 다릅니다</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-3">
        {domains.map((domain) => (
          <div class="p-5 rounded-xl bg-surface-container-low border border-transparent hover:border-outline-variant/20 transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-xl bg-primary-container flex items-center justify-center shrink-0">
                <Icon name={domain.icon} class="w-4 h-4 text-primary" />
              </div>
              <div class="min-w-0">
                <h4 class="font-semibold text-on-surface text-sm">{domain.label}</h4>
                <span class="text-[10px] text-on-surface-variant">{domain.description}</span>
              </div>
            </div>
            <div class="flex flex-col gap-1 text-xs text-on-surface-variant">
              <div class="flex justify-between"><span>모델</span><span class="font-bold text-on-surface">{domain.modelCount}</span></div>
              <div class="flex justify-between"><span>벤치마크</span><span class="font-bold text-on-surface">{domain.benchmarkCount}</span></div>
              <div class="flex justify-between"><span>점수</span><span class="font-bold text-on-surface">{domain.scoreCount}</span></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Filter Chips -->
    <div class="flex flex-wrap gap-3 mb-10">
      <button class="px-5 py-2.5 rounded-full bg-primary text-on-primary text-sm font-medium shadow-sm">All Models</button>
      <button class="px-5 py-2.5 rounded-full bg-surface-container text-on-surface-variant text-sm font-medium hover:bg-surface-container-high transition-colors">LLM</button>
      <button class="px-5 py-2.5 rounded-full bg-surface-container text-on-surface-variant text-sm font-medium hover:bg-surface-container-high transition-colors">Vision</button>
      <button class="px-5 py-2.5 rounded-full bg-surface-container text-on-surface-variant text-sm font-medium hover:bg-surface-container-high transition-colors">Audio</button>
      <button class="px-5 py-2.5 rounded-full bg-surface-container text-on-surface-variant text-sm font-medium hover:bg-surface-container-high transition-colors">Multimodal</button>
    </div>

    <!-- Data Grid Table -->
    <div class="overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr class="text-left border-b border-outline-variant/20">
            <th class="pb-6 pt-2 font-semibold text-on-surface-variant text-xs uppercase tracking-wider pl-4">모델 명칭</th>
            <th class="pb-6 pt-2 font-semibold text-on-surface-variant text-xs uppercase tracking-wider text-center">추론 (Reasoning)</th>
            <th class="pb-6 pt-2 font-semibold text-on-surface-variant text-xs uppercase tracking-wider text-center">지시 이행 (Instruction)</th>
            <th class="pb-6 pt-2 font-semibold text-on-surface-variant text-xs uppercase tracking-wider text-center">코딩 (Coding)</th>
            <th class="pb-6 pt-2 font-semibold text-on-surface-variant text-xs uppercase tracking-wider pr-4 text-right">라이선스</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/10">
          <tr class="group hover:bg-surface-container-low transition-all">
            <td class="py-6 pl-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary-container flex items-center justify-center">
                  <Icon name="material-symbols:smart-toy-outline" class="w-5 h-5 text-primary" />
                </div>
                <div>
                  <div class="font-semibold text-on-surface">GPT-4o</div>
                  <div class="text-xs text-on-surface-variant">OpenAI</div>
                </div>
              </div>
            </td>
            <td class="py-6 text-center"><span class="text-lg font-bold text-primary">94.2</span></td>
            <td class="py-6 text-center"><span class="text-lg font-medium">96.8</span></td>
            <td class="py-6 text-center"><span class="text-lg font-medium">91.5</span></td>
            <td class="py-6 pr-4 text-right"><span class="text-xs px-2 py-1 bg-surface-container-high rounded text-on-surface-variant">Proprietary</span></td>
          </tr>
          <tr class="group hover:bg-surface-container-low transition-all">
            <td class="py-6 pl-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-tertiary-container flex items-center justify-center">
                  <Icon name="material-symbols:psychology-outline" class="w-5 h-5 text-tertiary" />
                </div>
                <div>
                  <div class="font-semibold text-on-surface">Claude 3.5 Sonnet</div>
                  <div class="text-xs text-on-surface-variant">Anthropic</div>
                </div>
              </div>
            </td>
            <td class="py-6 text-center"><span class="text-lg font-bold text-primary">93.8</span></td>
            <td class="py-6 text-center"><span class="text-lg font-medium">97.2</span></td>
            <td class="py-6 text-center"><span class="text-lg font-medium">92.0</span></td>
            <td class="py-6 pr-4 text-right"><span class="text-xs px-2 py-1 bg-surface-container-high rounded text-on-surface-variant">Proprietary</span></td>
          </tr>
          <tr class="group hover:bg-surface-container-low transition-all">
            <td class="py-6 pl-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-surface-container flex items-center justify-center">
                  <Icon name="material-symbols:terminal" class="w-5 h-5 text-outline-variant" />
                </div>
                <div>
                  <div class="font-semibold text-on-surface">Llama 3 70B</div>
                  <div class="text-xs text-on-surface-variant">Meta</div>
                </div>
              </div>
            </td>
            <td class="py-6 text-center"><span class="text-lg font-bold text-primary">88.4</span></td>
            <td class="py-6 text-center"><span class="text-lg font-medium">89.1</span></td>
            <td class="py-6 text-center"><span class="text-lg font-medium">85.6</span></td>
            <td class="py-6 pr-4 text-right"><span class="text-xs px-2 py-1 bg-primary-container text-on-primary-container rounded font-medium">Llama 3</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="mt-12 flex justify-between items-center border-t border-outline-variant/10 pt-8">
      <div class="text-sm text-on-surface-variant">총 128개의 모델 중 상위 3개 표시 중</div>
      <div class="flex gap-4">
        <button class="text-sm font-semibold text-primary hover:underline">이전</button>
        <button class="text-sm font-semibold text-primary hover:underline">다음</button>
      </div>
    </div>

    <!-- Featured Section -->
    <section class="mt-24 grid grid-cols-1 md:grid-cols-12 gap-6">
      <div class="md:col-span-8 data-glass p-8 rounded-xl">
        <span class="text-[0.65rem] font-bold uppercase tracking-widest text-primary mb-4 block">주간 리포트</span>
        <h2 class="text-3xl font-bold mb-4">멀티모달 벤치마크의 부상</h2>
        <p class="text-on-surface-variant leading-relaxed max-w-xl">
          단순 텍스트 처리를 넘어 이미지, 오디오, 비디오를 통합적으로 이해하는 모델들이 리더보드 상위권을 점유하기 시작했습니다.
        </p>
      </div>
      <div class="md:col-span-4 bg-surface-container-low p-8 rounded-xl">
        <Icon name="material-symbols:verified" class="w-6 h-6 text-primary mb-4" />
        <h3 class="text-xl font-bold mb-2">검증된 데이터</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          모든 수치는 ModuBench의 독자적인 샌드박스 환경에서 3회 이상 반복 측정된 결과의 평균값입니다.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
