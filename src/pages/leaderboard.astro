---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import LeaderboardTable from '../components/common/LeaderboardTable.astro';

import llmModels from '../data/models/llm.json';
import imageGenModels from '../data/models/image-gen.json';
import ttsModels from '../data/models/tts.json';
import sttModels from '../data/models/stt.json';
import multimodalModels from '../data/models/multimodal.json';

import llmBenchmarks from '../data/benchmarks/llm.json';
import imageGenBenchmarks from '../data/benchmarks/image-gen.json';
import ttsBenchmarks from '../data/benchmarks/tts.json';
import sttBenchmarks from '../data/benchmarks/stt.json';
import multimodalBenchmarks from '../data/benchmarks/multimodal.json';

import type { BaseModel, BenchmarkDef, Score } from '../data/types';

// 발행된 모델 콘텐츠 슬러그 집합 — 상세 링크 활성화 판단에 사용
const publishedModelEntries = await getCollection(
  'models',
  ({ data }) => data.status === 'published',
);
const publishedSlugs = new Set(publishedModelEntries.map((e) => e.id));

const countScores = (scores: Record<string, Record<string, unknown>>) =>
  Object.values(scores).reduce((acc, modelScores) => acc + Object.keys(modelScores).length, 0);

interface DomainSection {
  id: string;
  label: string;
  description: string;
  icon: string;
  models: BaseModel[];
  benchmarks: BenchmarkDef[];
  scores: Record<string, Record<string, Score>>;
}

const domains: DomainSection[] = [
  {
    id: 'llm',
    label: 'LLM',
    description: '대규모 언어 모델',
    icon: 'material-symbols:chat-outline',
    models: llmModels.models as BaseModel[],
    benchmarks: llmBenchmarks.benchmarks as BenchmarkDef[],
    scores: llmBenchmarks.scores as Record<string, Record<string, Score>>,
  },
  {
    id: 'image-gen',
    label: '이미지 생성',
    description: 'Text-to-Image',
    icon: 'material-symbols:image-outline',
    models: imageGenModels.models as BaseModel[],
    benchmarks: imageGenBenchmarks.benchmarks as BenchmarkDef[],
    scores: imageGenBenchmarks.scores as Record<string, Record<string, Score>>,
  },
  {
    id: 'multimodal',
    label: '멀티모달',
    description: '복합 모달리티',
    icon: 'material-symbols:hub-outline',
    models: multimodalModels.models as BaseModel[],
    benchmarks: multimodalBenchmarks.benchmarks as BenchmarkDef[],
    scores: multimodalBenchmarks.scores as Record<string, Record<string, Score>>,
  },
  {
    id: 'tts',
    label: 'TTS',
    description: '음성 합성',
    icon: 'material-symbols:record-voice-over-outline',
    models: ttsModels.models as BaseModel[],
    benchmarks: ttsBenchmarks.benchmarks as BenchmarkDef[],
    scores: ttsBenchmarks.scores as Record<string, Record<string, Score>>,
  },
  {
    id: 'stt',
    label: 'STT',
    description: '음성 인식',
    icon: 'material-symbols:mic-outline',
    models: sttModels.models as BaseModel[],
    benchmarks: sttBenchmarks.benchmarks as BenchmarkDef[],
    scores: sttBenchmarks.scores as Record<string, Record<string, Score>>,
  },
];

const overview = domains.map((d) => ({
  id: d.id,
  label: d.label,
  description: d.description,
  icon: d.icon,
  modelCount: d.models.length,
  benchmarkCount: d.benchmarks.length,
  scoreCount: countScores(d.scores),
}));

const totalModels = overview.reduce((sum, d) => sum + d.modelCount, 0);
const totalScores = overview.reduce((sum, d) => sum + d.scoreCount, 0);
---

<BaseLayout title="AI 모델 성능 리더보드 - ModuBench">
  <main class="pt-32 pb-24 max-w-7xl mx-auto px-6">
    <!-- Hero Section -->
    <section class="mb-16">
      <div class="max-w-3xl">
        <span class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant mb-4 block">실시간 수집 데이터</span>
        <h1 class="text-5xl font-bold tracking-tight text-on-surface mb-6 leading-tight font-headline">AI 모델 성능 리더보드</h1>
        <p class="text-lg text-on-surface-variant leading-relaxed">
          Jules 자율 에이전트가 수집한 모델 메타데이터와 공개 벤치마크 점수를 도메인별로 정리합니다.
          모든 점수에는 출처(official · community · reproduced)가 명시되어 있습니다.
        </p>
      </div>
    </section>

    <!-- 도메인별 수집 현황 -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-lg font-semibold tracking-tight text-on-surface font-headline">도메인별 수집 현황</h2>
        <span class="text-xs text-on-surface-variant font-label">도메인별로 평가 방식·단위가 다릅니다</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-3">
        {overview.map((d) => (
          <a
            href={`#leaderboard-${d.id}`}
            class="p-5 rounded-xl bg-surface-container-low border border-transparent hover:border-outline-variant/30 transition-all"
          >
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-xl bg-primary-container flex items-center justify-center shrink-0">
                <Icon name={d.icon} class="w-4 h-4 text-primary" />
              </div>
              <div class="min-w-0">
                <h4 class="font-semibold text-on-surface text-sm">{d.label}</h4>
                <span class="text-[10px] text-on-surface-variant">{d.description}</span>
              </div>
            </div>
            <div class="flex flex-col gap-1 text-xs text-on-surface-variant">
              <div class="flex justify-between"><span>모델</span><span class="font-bold text-on-surface">{d.modelCount}</span></div>
              <div class="flex justify-between"><span>벤치마크</span><span class="font-bold text-on-surface">{d.benchmarkCount}</span></div>
              <div class="flex justify-between"><span>점수</span><span class="font-bold text-on-surface">{d.scoreCount}</span></div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- 도메인별 리더보드 표 -->
    {domains.map((d) => (
      <LeaderboardTable
        domainId={d.id}
        domainLabel={d.label}
        domainDescription={d.description}
        domainIcon={d.icon}
        models={d.models}
        benchmarks={d.benchmarks}
        scores={d.scores}
        publishedSlugs={publishedSlugs}
      />
    ))}

    <!-- 푸터 요약 -->
    <div class="mt-12 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 border-t border-outline-variant/10 pt-8 text-sm text-on-surface-variant">
      <div>총 <span class="font-semibold text-on-surface">{totalModels}</span>개 모델 · <span class="font-semibold text-on-surface">{totalScores}</span>건의 점수가 수집되어 있습니다.</div>
      <div class="text-xs">상세 페이지 링크가 회색인 모델은 프로필 작성 대기 중입니다.</div>
    </div>

    <!-- Featured Section -->
    <section class="mt-24 grid grid-cols-1 md:grid-cols-12 gap-6">
      <div class="md:col-span-8 data-glass p-8 rounded-xl">
        <span class="text-[0.65rem] font-bold uppercase tracking-widest text-primary mb-4 block">파이프라인 메모</span>
        <h2 class="text-3xl font-bold mb-4">자동 수집의 신뢰도</h2>
        <p class="text-on-surface-variant leading-relaxed max-w-xl">
          모든 모델 메타데이터와 점수는 Jules 에이전트의 사이클을 통해 수집됩니다.
          데이터 검증과 출처 추적은 <code class="text-primary">src/data/</code> JSON 스키마와
          빌드 시점의 Zod 검증으로 이중 보장됩니다.
        </p>
      </div>
      <div class="md:col-span-4 bg-surface-container-low p-8 rounded-xl">
        <Icon name="material-symbols:verified" class="w-6 h-6 text-primary mb-4" />
        <h3 class="text-xl font-bold mb-2">출처 명시</h3>
        <p class="text-sm text-on-surface-variant leading-relaxed">
          각 점수에는 official(공식 발표) · community(커뮤니티 재현) · reproduced(자체 측정) 라벨이 붙습니다.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
