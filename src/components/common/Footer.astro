---
const footerLinks = [
  { label: 'Terms', href: '#' },
  { label: 'Privacy', href: '#' },
  { label: 'GitHub', href: '#' },
  { label: 'Contact', href: '#' },
];
---

<footer class="w-full py-12 border-t border-outline-variant/20 bg-surface-container-low">
  <div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-6">
    <div class="flex flex-col items-center md:items-start gap-2">
      <span class="font-bold text-on-surface font-headline">ModuBench</span>
      <p class="text-sm text-on-surface-variant">
        &copy; {new Date().getFullYear()} ModuBench. Open-source AI Benchmark Hub.
      </p>
    </div>
    <div class="flex gap-6">
      {footerLinks.map(({ label, href }) => (
        <a
          href={href}
          class="text-sm text-on-surface-variant hover:text-primary transition-all duration-200 hover:underline decoration-primary/30 underline-offset-4"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>
