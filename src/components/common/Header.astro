---
import { Icon } from 'astro-icon/components';
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: 'Home', href: `${import.meta.env.BASE_URL}` },
  { label: 'Leaderboard', href: `${import.meta.env.BASE_URL}leaderboard` },
  { label: 'Tools', href: `${import.meta.env.BASE_URL}resources` },
  { label: 'News', href: `${import.meta.env.BASE_URL}news` },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-xl border-b border-outline-variant/20">
  <div class="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto w-full">
    <div class="flex items-center gap-8">
      <a href={import.meta.env.BASE_URL} class="text-xl font-bold tracking-tighter text-on-surface font-headline">
        ModuBench
      </a>
      <nav class="hidden md:flex items-center gap-6">
        {navItems.map(({ label, href }) => {
          const isActive = currentPath === href || (href !== import.meta.env.BASE_URL && currentPath.startsWith(href));
          return (
            <a
              href={href}
              class:list={[
                'text-sm font-medium transition-colors',
                isActive
                  ? 'text-primary font-semibold border-b-2 border-primary pb-1'
                  : 'text-on-surface-variant hover:text-primary',
              ]}
            >
              {label}
            </a>
          );
        })}
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <div class="relative hidden sm:block">
        <Icon name="material-symbols:search" class="absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant w-4 h-4" />
        <input
          class="pl-10 pr-4 py-2 bg-surface-container-high border-none rounded-lg text-sm text-on-surface focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 transition-all w-48 lg:w-64"
          placeholder="검색..."
          type="text"
        />
      </div>
      <ThemeToggle />
      <a
        href="https://github.com/GGJJack/modu-bench"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2 hover:bg-surface-container rounded-md transition-all"
        aria-label="GitHub 저장소"
      >
        <Icon name="material-symbols:code" class="w-6 h-6 text-on-surface-variant" />
      </a>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 hover:bg-surface-container rounded-md transition-all">
        <Icon name="material-symbols:menu" class="w-6 h-6 text-on-surface-variant" />
      </button>
    </div>
  </div>

  <!-- Mobile navigation -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-outline-variant/20 bg-background/95 backdrop-blur-xl">
    <div class="px-6 py-4 flex flex-col gap-3">
      {navItems.map(({ label, href }) => {
        const isActive = currentPath === href || (href !== import.meta.env.BASE_URL && currentPath.startsWith(href));
        return (
          <a
            href={href}
            class:list={[
              'text-sm font-medium py-2 transition-colors',
              isActive
                ? 'text-primary font-semibold'
                : 'text-on-surface-variant',
            ]}
          >
            {label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
